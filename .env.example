# Site
NEXT_PUBLIC_SITE_URL=https://nexaprime.digital

# Database (SQLite for local dev; use PostgreSQL URL in production)
DATABASE_URL="file:./dev.db"

# Admin dashboard
ADMIN_PASSWORD=change-me-in-production
ADMIN_SESSION_SECRET=generate-a-long-random-string-here

# Contact form — set in production (Vercel/host env vars, never commit real values)
# CONTACT_FORM_ENDPOINT=https://your-form-handler.example/webhook
# CONTACT_FORM_API_KEY=

# Free consultation booking (Cal.com or Calendly — instant calendar confirmation)
# NEXT_PUBLIC_BOOKING_PROVIDER=calcom
# NEXT_PUBLIC_BOOKING_URL=nexaprime-digital/consultation
# Calendly example:
# NEXT_PUBLIC_BOOKING_PROVIDER=calendly
# NEXT_PUBLIC_BOOKING_URL=your-team/20min

# Analytics (optional — production Web Vitals reporting endpoint)
# NEXT_PUBLIC_WEB_VITALS_ENDPOINT=https://your-analytics-endpoint.example/vitals
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
